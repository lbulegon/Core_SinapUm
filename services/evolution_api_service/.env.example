# Evolution API - variaveis de ambiente
# Copie para .env e preencha. NUNCA commitar .env com credenciais.

# Modo: image (padrao) | build (aplica patch 21/jan PR #2365)
EVOLUTION_MODE=image

# Imagem (modo image)
EVOLUTION_IMAGE=atendai/evolution-api
EVOLUTION_IMAGE_TAG=v2.2.3

# Portas (8004:8080 preservadas)
EVOLUTION_PORT_EXTERNAL=8004
EVOLUTION_PORT_INTERNAL=8080

# URLs e credenciais (OBRIGATORIAS)
EVOLUTION_SERVER_URL=http://SEU_IP:8004
EVOLUTION_API_KEY=CHAVE_AQUI
EVOLUTION_DB_URI=postgresql://USER:PASSWORD@host.docker.internal:5433/evolution
EVOLUTION_WEBHOOK_URL=http://host.docker.internal:8000/api/whatsapp/webhook/evolution/

# Logs
EVOLUTION_LOG_LEVEL=INFO
EVOLUTION_LOG_BAILEYS=info

# Opcionais
EVOLUTION_QRCODE_LIMIT=30
EVOLUTION_QRCODE_COLOR=#198754
EVOLUTION_DATABASE_ENABLED=true
EVOLUTION_WEBHOOK_ENABLED=true
EVOLUTION_REDIS_PORT=6379
