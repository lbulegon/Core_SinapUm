# WhatsApp Gateway Service - Variáveis de Ambiente

PORT=8007
API_KEY=<sua-api-key-segura>
AUTH_DIR=/data/auth

# Webhook legado (opcional - Core recebe eventos)
WEBHOOK_URL=http://core:5000/webhooks/whatsapp/

# Event Bus (Redis Streams) - Publicar eventos para múltiplos consumidores
EVENT_BUS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Auto-conectar ao iniciar
AUTO_CONNECT=false
