# ============================================================
# MLflow Service - Environment Variables
# ============================================================
# Copie este arquivo para .env e ajuste conforme necessário:
#   cp .env.example .env
# ============================================================

# Porta do host para acessar a UI do MLflow (host -> container 5000)
MLFLOW_HOST_PORT=5050

# Backend store: URI do PostgreSQL onde o MLflow persiste runs/experiments
# O hostname 'mlflow_postgres' refere-se ao container Postgres dedicado do MLflow
MLFLOW_BACKEND_URI=postgresql://mlflow_user:mlflow_pass@mlflow_postgres:5432/mlflow_db

# Diretório de artifacts dentro do container (persistido via volume Docker)
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# URI de tracking para clientes Python conectarem ao MLflow
# Use esta variável nos scripts/notebooks que logam experimentos
MLFLOW_TRACKING_URI=http://localhost:5050

# ============================================================
# Postgres dedicado do MLflow (usado pelo container mlflow_postgres)
# ============================================================
MLFLOW_POSTGRES_DB=mlflow_db
MLFLOW_POSTGRES_USER=mlflow_user
MLFLOW_POSTGRES_PASSWORD=mlflow_pass
