# Configurações do Django
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,69.169.102.84

# Configurações do PostgreSQL
POSTGRES_DB=mcp_sinapum
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=mcp_password_change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mcp_user:mcp_password_change_me@db:5432/mcp_sinapum

# Configurações do OpenMind AI
OPENMIND_AI_URL=http://host.docker.internal:8000
OPENMIND_AI_KEY=om1_live_7d4102a1bf72cc497d7651beb6a98292764b1f77df947c82d086506038ea6b9921efb9d9833045d1

# Opcional: Criar superusuário na inicialização (apenas desenvolvimento)
CREATE_SUPERUSER=False

# WorldGraph Service (Neo4j) - Memória Diagramática
WORLDGRAPH_NEO4J_USER=neo4j
WORLDGRAPH_NEO4J_PASSWORD=neo4j12345
WORLDGRAPH_HTTP_PORT=7474
WORLDGRAPH_BOLT_PORT=7687
WORLDGRAPH_HEAP_INITIAL=1G
WORLDGRAPH_HEAP_MAX=1G
WORLDGRAPH_PAGECACHE=1G

# Vectorstore Service (FAISS) - Memória Semântica / RAG (core.rag_query, EOC, feedback MrFoo)
VECTORSTORE_PORT=8010
VECTORSTORE_DATA_DIR=/data
VECTORSTORE_MODEL=all-MiniLM-L6-v2
# URL vista pelo container Django `web` (compose: http://vectorstore_service:8010)
# VECTORSTORE_URL=http://vectorstore_service:8010
# VECTORSTORE_TIMEOUT=15

# =============================================================================
# MCP / ACP — Chamadas ao MCP Service e timeout de execução
# =============================================================================
# URL do MCP Service (Docker: http://mcp_service:7010 | local: http://localhost:7010)
MCP_SERVICE_URL=http://mcp_service:7010
# Timeout em segundos para chamadas MCP na execução ACP
ACP_MCP_TIMEOUT=120
# Opcional: token para MCP (se não definido, usa INTERNAL_API_TOKEN)
# SINAPUM_API_KEY=
# Opcional: URL completa do /mcp/call (sobrescreve MCP_SERVICE_URL se definida)
# MCP_CALL_URL=http://mcp_service:7010/mcp/call

# =============================================================================
# Event Bus (Redis Streams) - Para whatsapp_gateway_service e consumidores
# =============================================================================
REDIS_URL=redis://localhost:6379/0
# Estado ambiental (Mapa de Estado Ambiental) — use DB dedicado em prod (ex.: /2) se Celery usar /0 e /1
# REDIS_TTL_ENV_STATE=300
# ENV_HISTORY_MAX_LEN=100
# ENVIRONMENTAL_STATE_REDIS_ENABLED=true
# Habilitar no gateway: EVENT_BUS_ENABLED=true (publica em whatsapp.inbound)
# EVENT_BUS_ENABLED=true

# =============================================================================
# Núcleo cognitivo (cognitive_core) — orquestração semiótica operacional
# =============================================================================
# COGNITIVE_CORE_USE_ORCHESTRATOR=true  # inbound WhatsApp via CognitiveOrchestrator (false = fluxo legado)
# COGNITIVE_CORE_RAG_NAMESPACES=global,mrfoo  # namespaces → prefixo id no vectorstore (exceto "global")
# COGNITIVE_CORE_INCLUDE_LOCAL_ORM_METRICS=true  # métricas do pipeline (DecisionLog/InboundEvent) em operational_live
# COGNITIVE_AUTONOMY_LEVEL=0   # 0=off, 1=insights, 2=propostas+DecisionEngine, 3=exec ACP após safety
# COGNITIVE_AUTONOMY_MIN_CONFIDENCE=0.72
# COGNITIVE_AUTONOMY_MAX_RISK_AUTO=medium
# COGNITIVE_AUTONOMY_EXECUTE_TOOL=noop
# COGNITIVE_AUTONOMY_MAX_PROPOSALS=3      # máx. ações após ranking+simulação por ciclo
# COGNITIVE_AUTONOMY_MAX_INSIGHTS=5       # quantos insights ranqueados geram candidatos
# COGNITIVE_STRATEGIC_OBJECTIVES=reduzir_atraso,maximizar_throughput,manter_estabilidade
# COGNITIVE_STRATEGIC_WEIGHTS_JSON={"reduzir_atraso":0.5,"maximizar_throughput":0.3}
# STRATEGIC_DELAY_COST_PER_HOUR=15   # custo monetário proxy por hora de atraso agregado (KPI)
# STRATEGIC_LPH_NORM=80            # normalização lucro/hora para score de produto
# WORLDGRAPH_BOLT_URL=bolt://worldgraph:7687  # opcional — consultas Cypher (WORLDGRAPH_TENANT_CYPHER / WORLDGRAPH_DEFAULT_CYPHER)
# WORLDGRAPH_HTTP_URL=  # opcional — gateway HTTP POST /cypher {query, params}

# =============================================================================
# MrFoo — adapter HTTP + tools mrfoo.graph.* (Core chama API do orbital)
# =============================================================================
# MRFOO_BASE_URL=https://mrfoo-development.up.railway.app
# MRFOO_API_TOKEN=   # mesmo valor que GRAPH_API_TOKEN no MrFoo

# =============================================================================
# PR3 — Feature flags MCP/ACP/A2A
# =============================================================================
# ACP_ENABLED=true   # false = /a2a/run executa síncrono via MCP
# MCP_RESOURCES_ENABLED=true   # false = /core/resources/ retorna 404 controlado
# A2A_ENABLED=true   # false = /a2a/run retorna 503
# DUAL_RUN_ENABLED=false   # true = executa sync + ACP e loga divergência

# =============================================================================
# SinapLint — endpoint interno /api/sinaplint/internal/engine/ (produto SinapLint SaaS)
# =============================================================================
# Segredo partilhado: o mesmo valor em SinapLint como SINAPLINT_ENGINE_API_KEY.
# Se vazio: em DEBUG o endpoint aceita sem header; em produção sem segredo → 503.
# SINAPLINT_ENGINE_SHARED_SECRET=
# Timeout (segundos) para git clone quando POST inclui repo_url (repositórios grandes).
# SINAPLINT_ENGINE_CLONE_TIMEOUT=300
# Binário git (default: git no PATH).
# SINAPLINT_ENGINE_GIT_BIN=git
